generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SECRETARY") // ADMIN, OPERATOR, SECRETARY
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processos Processo[]
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  nif       String   @unique
  cc        String?
  telefone  String
  email     String?
  morada    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processos Processo[]
}

model Veiculo {
  id          String   @id @default(cuid())
  matricula   String   @unique
  marca       String
  modelo      String
  ano         Int?
  vin         String?
  combustivel String?
  cor         String?
  quilometros Int?
  estado      String?  // Estado físico do veículo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  processo Processo?
}

model Processo {
  id              String   @id @default(cuid())
  numero          String   @unique // ex: "VFV-2026-001"
  estado          String   @default("LEAD") // LEAD, COTACAO, AGENDADO, RECOLHIDO, MODELO9, VALORCAR, CERTIFICADO, CONCLUIDO
  cotacao         Float?
  dataAgendamento DateTime?
  horaAgendamento String?
  localRecolha    String?
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cliente   Cliente @relation(fields: [clienteId], references: [id])
  clienteId String

  veiculo   Veiculo @relation(fields: [veiculoId], references: [id])
  veiculoId String  @unique

  responsavel User?   @relation(fields: [userId], references: [id])
  userId      String?

  documentos Documento[]
}

model Documento {
  id        String   @id @default(cuid())
  tipo      String // DUA, LIVRETE, CC, MODELO9, CERTIFICADO, FOTO, OUTRO
  nome      String
  path      String
  createdAt DateTime @default(now())

  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  processoId String
}
